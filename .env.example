# MiMo API（TTS 合成 + Director Agent 共用）
MIMO_API_KEY=your_mimo_api_key_here
# Token Plan 用户用: https://token-plan-cn.xiaomimimo.com/v1
# 标准 API 用户用: https://api.xiaomimimo.com/v1
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# Director Agent LLM（可选，不填则复用 MIMO_API_KEY）
# 如果想用其他 LLM（如 GPT-4o）做导演分析，取消注释并填入
# LLM_API_KEY=your_other_llm_key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# TTS 默认配置
LLM_MODEL=mimo-v2.5-flash
TTS_MODEL=mimo-v2.5-tts
DEFAULT_VOICE=Chloe
MAX_CONCURRENCY=10
MAX_CHUNK_CHARS=500
OUTPUT_DIR=output
