{
  "manifest_version": 2,
  "name": "TTS Read Aloud",
  "version": "1.2.0",
  "description": "多引擎 TTS 朗读扩展（MiMo / AstraTTS / MOSS）",
  "permissions": ["activeTab", "storage", "contextMenus", "http://localhost/*", "http://127.0.0.1/*"],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tts-read-aloud@tts-platform",
      "strict_min_version": "91.0"
    }
  }
}
